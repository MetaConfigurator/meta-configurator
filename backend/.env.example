# Joint backend deployment — environment variables.
#
# Copy to `.env` next to docker-compose.yml and edit. Every variable is
# required by the joint stack.

# Public hostname all backend services share. Routing is by URL path.
BASE_DOMAIN=metaconfigurator.informatik.uni-stuttgart.de

# Contact email for Let's Encrypt certificate issuance / expiry notices.
LETSENCRYPT_EMAIL=felix.neubauer@ipvs.uni-stuttgart.de

# Snapshot-sharing storage secrets.
MONGO_PASS=change-me
REDIS_PASS=change-me
