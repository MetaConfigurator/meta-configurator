# -----------------------------------------------------------------------
# Deployment (docker-compose)
# -----------------------------------------------------------------------

# Host port for the local (no-HTTPS) docker compose.
RELAY_PORT=8080

# Public hostname for docker-compose.https.yml (standalone HTTPS deploy).
# For the joint backend deployment this is ignored — see ../docker-compose.yml.
RELAY_HOSTNAME=relay.metaconfigurator.informatik.uni-stuttgart.de
LETSENCRYPT_EMAIL=felix.neubauer@ipvs.uni-stuttgart.de

# -----------------------------------------------------------------------
# Legacy env-var config (the current app.py reads from config.yaml; the
# values below are kept for reference / future use).
# -----------------------------------------------------------------------

# Credentials MC uses to authenticate to this relay (HTTP Basic Auth).
# Use a strong, randomly generated password.
MC_RELAY_USERNAME=mc
MC_RELAY_PASSWORD=change-me

# Your LLM provider base URL.
# Examples:
#   https://api.openai.com/v1
#   https://openrouter.ai/api/v1
#   http://localhost:11434/v1   (Ollama)
UPSTREAM_BASE_URL=https://api.openai.com/v1

# Your provider API key — stays on the server, never sent to the browser.
UPSTREAM_API_KEY=sk-...

# -----------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------

# MC frontend origin allowed by the relay.
# Must be exact (no trailing slash, no wildcards).
# Example: https://felixneubauer.github.io
ALLOWED_ORIGIN=https://your-mc-app.example.com

# -----------------------------------------------------------------------
# Upstream auth customization (optional)
# -----------------------------------------------------------------------

# Header name the relay uses when authenticating to the upstream.
# Default: Authorization
# UPSTREAM_AUTH_HEADER=Authorization

# Prefix placed before the API key in the auth header value.
# Default: Bearer   →  "Authorization: Bearer sk-..."
# Set to empty string for providers that want the raw key only.
# UPSTREAM_AUTH_PREFIX=Bearer

# Extra path segment inserted before forwarded paths.
# Useful if your upstream gateway requires a version prefix not in the base URL.
# UPSTREAM_PATH_PREFIX=

# -----------------------------------------------------------------------
# Timeouts and limits (optional)
# -----------------------------------------------------------------------

# Seconds to wait for an upstream response before returning 504.
# Default: 180
# REQUEST_TIMEOUT_SECONDS=180

# Maximum request body size in bytes. Requests larger than this return 413.
# Default: 2097152 (2 MB)
# MAX_REQUEST_BYTES=2097152

# -----------------------------------------------------------------------
# Feature flags (optional)
# -----------------------------------------------------------------------

# Expose GET /v1/models to MC. Default: true
# ENABLE_MODELS_PROXY=true

# Pass through streaming (SSE) responses. Default: true
# ENABLE_STREAMING=true

# -----------------------------------------------------------------------
# Logging (optional)
# -----------------------------------------------------------------------

# DEBUG, INFO, WARNING, ERROR. Default: INFO
# LOG_LEVEL=INFO

# -----------------------------------------------------------------------
# Advanced (optional)
# -----------------------------------------------------------------------

# Static headers merged into every upstream request, as a JSON object.
# Useful for providers that require extra metadata.
# Example: {"HTTP-Referer": "https://your-mc-app.example.com", "X-Title": "MetaConfigurator"}
# UPSTREAM_EXTRA_HEADERS_JSON=
